# MMU Clearance System — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

SECRET_KEY=your-secret-key-here-generate-with-python-secrets

DEBUG=True

# PostgreSQL — Supabase (production) or local (development)
DATABASE_URL=postgresql://postgres:password@localhost:5432/mmu_clearance

# Cloudinary — for uploaded supporting documents
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Gmail SMTP — for email notifications
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST_USER=yourgmail@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password_16_chars

# Vercel URL (auto-set by Vercel, set manually for local testing)
VERCEL_URL=localhost
